# Google Service Account (required for live sheet read/write)
# 1. Create at console.cloud.google.com → IAM → Service Accounts → Create key (JSON)
# 2. Save as service-account.json in this folder
# 3. Share BOTH sheets with the service account email (Editor):
#    - HR data: 17z8JrLV0_4fSXzsiZRpCZWFJk5FTit3IUkw0c3NOkvU
#    - HR Access: 1i4KR3e_jNtPMTSDFnbpS7kYzExqEyA0CgLlaZg5KoF8

GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

# HR data sheet
SHEET_ID=17z8JrLV0_4fSXzsiZRpCZWFJk5FTit3IUkw0c3NOkvU

# HR logs / audit sheet (optional — also mirrors Change_Log on HR Data)
LOG_SHEET_ID=14vcc32AvyXI6PEUPbCd5IBoTfhEirAorGX1xMI75h9Y
LOG_SHEET_TAB=Change_Log

# HR Access sheet (User / Password / status / Role)
AUTH_SHEET_ID=1i4KR3e_jNtPMTSDFnbpS7kYzExqEyA0CgLlaZg5KoF8

# App version policy tab on the HR Access sheet (see SHEET_SCHEMA.md)
VERSION_SHEET_TAB=App_Versions

# Google Drive folder for documents & profile photos (shared with service account)
GOOGLE_DRIVE_FOLDER_ID=1rfPMKlIqbJ_eKpwXIpHPKW_vfR7VXVUe

# Transport allowance applies from this month onward (YYYY-MM). Earlier months = not eligible.
TRANSPORT_ELIGIBLE_FROM_MONTH=2026-07

SESSION_SECRET=change-this-to-a-long-random-string
PORT=3847

# --- Supabase (set DATA_BACKEND=supabase after running npm run migrate:supabase) ---
DATA_BACKEND=sheets
# Dashboard → Project Settings → API
SUPABASE_URL=https://ugntjwqimgosuiodsnnk.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-sb_publishable_key_here
# Required for server/admin operations (never commit the real value):
SUPABASE_SECRET_KEY=your-sb_secret_key_here
# JWT verification for auth: "user" routes (auto-derived from project URL):
SUPABASE_JWKS_URL=https://ugntjwqimgosuiodsnnk.supabase.co/auth/v1/.well-known/jwks.json
# For applying DDL migrations (Dashboard → Account → Access Tokens):
# SUPABASE_ACCESS_TOKEN=your_personal_access_token
# Or database password (Dashboard → Database):
# SUPABASE_DB_PASSWORD=your_database_password

# GitHub in-app updates (desktop unpacked / portable builds)
# Full guide: UPDATES.md
# Set to owner/repo — does NOT replace building installers on your PC.
GITHUB_UPDATES_REPO=raymondwalkerhs-spec/hangup-hr
# Optional token for private repos or higher API rate limits:
# GITHUB_UPDATES_TOKEN=
