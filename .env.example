# Hangup HR — Supabase (required)
DATA_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_sb_publishable_key
SUPABASE_SECRET_KEY=your_sb_secret_key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_ACCESS_TOKEN=your_personal_access_token
# SUPABASE_DB_PASSWORD=your_database_password

TRANSPORT_ELIGIBLE_FROM_MONTH=2026-07
SESSION_SECRET=change-this-to-a-long-random-string
PORT=3847

# GitHub in-app updates (desktop)
GITHUB_UPDATES_REPO=owner/repo
# GITHUB_UPDATES_TOKEN=ghp_... (required for private repos)

# Dropbox (sales attachments)
# DROPBOX_ACCESS_TOKEN=
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=

# Airtable (outbound sales sync — optional)
# AIRTABLE_API_KEY=pat...
# AIRTABLE_BASE_ID=app...
# AIRTABLE_BASE_ID=app...   # must be a base your token can access
# AIRTABLE_TABLE_NAME=MLA     # e.g. MLA in Internal Main 2026 (not always "Sales All Data")
# AIRTABLE_SYNC_ENABLED=true
# AIRTABLE_SYNC_DEBOUNCE_MS=0
# AIRTABLE_ATTACHMENT_URL_TTL_SEC=7200
# AIRTABLE_SKIP_ATTACHMENT_KINDS=   # empty = sync all attachment columns present on the table
# AIRTABLE_PORTAL_SALE_ID_FIELD=Portal Sale ID   # set to empty to disable upsert lookup

# Google Sheets / Drive is deprecated — see LEGACY_GOOGLE_SHEETS.md (do not use in production)
